@functions {
    static string GetTitle(string path, Dictionary<string, string> names)
    {
        var fileName = System.IO.Path.GetFileNameWithoutExtension(path);
        return names.ContainsKey(fileName) ? names[fileName] : fileName;
    }
}

@{
    ViewData["Title"] = "Análise Exploratória de Dados";
    var pngCharts = ViewBag.PngCharts as List<string> ?? new List<string>();
    var htmlCharts = ViewBag.HtmlCharts as List<string> ?? new List<string>();
    var hasCharts = pngCharts.Any() || htmlCharts.Any();

    var chartNames = new Dictionary<string, string>
    {
        { "01_top15_items", "Top 15 Itens Mais Vendidos" },
        { "02_pie_top10", "Distribuição de Vendas ; Top 10" },
        { "03_period_of_day", "Vendas por Período do Dia" },
        { "04_weekday_weekend", "Dia Útil vs Fim de Semana" },
        { "05_heatmap_item_period", "Heatmap: Itens x Período" },
        { "06_heatmap_item_dayofweek", "Heatmap: Itens x Dia da Semana" },
        { "07_stacked_period_ww", "Período do Dia ; Dia Útil vs Fim de Semana" },
        { "08_daily_transactions", "Transações Diárias ao Longo do Tempo" },
        { "09_monthly_sales", "Volume Mensal de Vendas" },
        { "10_hourly_distribution", "Distribuição de Vendas por Hora" },
        { "11_treemap", "Treemap: Itens por Período" },
        { "12_sunburst", "Sunburst: Tipo de Dia → Período → Item" },
        { "13_bubble_hour_day", "Bubble Chart: Hora x Dia da Semana" },
        { "14_violin_hour_period", "Violino: Distribuição por Hora/Período" },
        { "15_top5_monthly_facet", "Tendência Mensal ; Top 5 Itens" },
        { "16_day_of_week_bar", "Vendas por Dia da Semana" },
        { "17_heatmap_item_hour", "Heatmap: Itens x Hora" },
        { "18_transaction_size", "Análise do Tamanho das Transações" }
    };

    var allCharts = pngCharts.Concat(htmlCharts).OrderBy(c => System.IO.Path.GetFileName(c)).ToList();

    var univariate = allCharts.Where(c => {
        var name = System.IO.Path.GetFileName(c);
        return name.StartsWith("01") || name.StartsWith("02") || name.StartsWith("03") || name.StartsWith("04");
    }).ToList();

    var bivariate = allCharts.Where(c => {
        var name = System.IO.Path.GetFileName(c);
        return name.StartsWith("05") || name.StartsWith("06") || name.StartsWith("07");
    }).ToList();

    var timeseries = allCharts.Where(c => {
        var name = System.IO.Path.GetFileName(c);
        return name.StartsWith("08") || name.StartsWith("09") || name.StartsWith("10");
    }).ToList();

    var advanced = allCharts.Where(c => {
        var name = System.IO.Path.GetFileName(c);
        return int.TryParse(name.Substring(0, 2), out int n) && n >= 11;
    }).ToList();
}

<div class="bg-primary text-white rounded-3 p-4 mb-4 text-center shadow">
    <h1 class="display-5 fw-bold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-bar-chart-line me-2 mb-1" viewBox="0 0 16 16">
            <path d="M11 2a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v12h.5a.5.5 0 0 1 0 1H.5a.5.5 0 0 1 0-1H1v-3a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v3h1V7a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v7h1zm1 12h2V2h-2zm-3 0h2V7H9zm-3 0h2v-3H6z" />
        </svg>
        Análise Exploratória de Dados
    </h1>
    <p class="lead mb-0">Visualizações geradas a partir dos dados de vendas da padaria</p>
</div>

@if (!hasCharts)
{
    <div class="alert alert-warning text-center shadow-sm" role="alert">
        <h5 class="alert-heading fw-bold">Nenhum gráfico encontrado</h5>
        <p class="mb-2">Execute o script Python para gerar as visualizações:</p>
        <code class="d-block bg-dark text-light rounded p-2 mx-auto" style="max-width:500px;">
            python Data_Analitics/src/main.py
        </code>
    </div>
}
else
{
    <!-- Section navigation -->
    <nav class="mb-4">
        <div class="d-flex flex-wrap gap-2 justify-content-center">
            <a href="#univariate" class="btn btn-outline-primary btn-sm">Univariada</a>
            <a href="#bivariate" class="btn btn-outline-primary btn-sm">Bivariada</a>
            <a href="#timeseries" class="btn btn-outline-primary btn-sm">Séries Temporais</a>
            <a href="#advanced" class="btn btn-outline-primary btn-sm">Avançada</a>
        </div>
    </nav>

    <!-- Univariate Analysis -->
    <section id="univariate" class="mb-5">
        <h3 class="fw-bold mb-3 border-start border-primary border-4 ps-3">Análise Univariada</h3>
        <div class="row">
            @foreach (var chart in univariate)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="card-title mb-0 fw-semibold">@GetTitle(chart, chartNames)</h5>
                        </div>
                        <div class="card-body text-center p-3">
                            @if (chart.EndsWith(".png"))
                            {
                                <img src="@chart" alt="@GetTitle(chart, chartNames)" class="img-fluid rounded" style="max-height: 600px;" />
                            }
                            else
                            {
                                <iframe src="@chart" style="width:100%; height:500px; border:none;" loading="lazy"></iframe>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Bivariate Analysis -->
    <section id="bivariate" class="mb-5">
        <h3 class="fw-bold mb-3 border-start border-success border-4 ps-3">Análise Bivariada / Multivariada</h3>
        <div class="row">
            @foreach (var chart in bivariate)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="card-title mb-0 fw-semibold">@GetTitle(chart, chartNames)</h5>
                        </div>
                        <div class="card-body text-center p-3">
                            @if (chart.EndsWith(".png"))
                            {
                                <img src="@chart" alt="@GetTitle(chart, chartNames)" class="img-fluid rounded" style="max-height: 600px;" />
                            }
                            else
                            {
                                <iframe src="@chart" style="width:100%; height:500px; border:none;" loading="lazy"></iframe>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Time Series -->
    <section id="timeseries" class="mb-5">
        <h3 class="fw-bold mb-3 border-start border-info border-4 ps-3">Séries Temporais</h3>
        <div class="row">
            @foreach (var chart in timeseries)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom">
                            <h5 class="card-title mb-0 fw-semibold">@GetTitle(chart, chartNames)</h5>
                        </div>
                        <div class="card-body text-center p-3">
                            @if (chart.EndsWith(".png"))
                            {
                                <img src="@chart" alt="@GetTitle(chart, chartNames)" class="img-fluid rounded" style="max-height: 600px;" />
                            }
                            else
                            {
                                <iframe src="@chart" style="width:100%; height:500px; border:none;" loading="lazy"></iframe>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <!-- Advanced -->
    <section id="advanced" class="mb-5">
        <h3 class="fw-bold mb-3 border-start border-warning border-4 ps-3">Visualizações Avançadas</h3>
        <div class="row">
            @foreach (var chart in advanced)
            {
                <div class="col-12">
                    <div class="card border-0 shadow-sm mb-4">
                        <div class="card-header bg-white border-bottom d-flex justify-content-between align-items-center">
                            <h5 class="card-title mb-0 fw-semibold">@GetTitle(chart, chartNames)</h5>
                            @if (!chart.EndsWith(".png"))
                            {
                                <a href="@chart" target="_blank" class="btn btn-sm btn-outline-secondary">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" class="bi bi-box-arrow-up-right me-1" viewBox="0 0 16 16">
                                        <path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5"/>
                                        <path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0z"/>
                                    </svg>
                                    Abrir
                                </a>
                            }
                        </div>
                        <div class="card-body text-center p-3">
                            @if (chart.EndsWith(".png"))
                            {
                                <img src="@chart" alt="@GetTitle(chart, chartNames)" class="img-fluid rounded" style="max-height: 600px;" />
                            }
                            else
                            {
                                <iframe src="@chart" style="width:100%; height:500px; border:none;" loading="lazy"></iframe>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}
