@{
    ViewData["Title"] = "Notebook ; Análise de Dados";
    bool reportExists = ViewBag.ReportExists ?? false;
}

<div class="bg-primary text-white rounded-3 p-4 mb-4 text-center shadow">
    <h1 class="display-5 fw-bold mb-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" fill="currentColor" class="bi bi-journal-code me-2 mb-1" viewBox="0 0 16 16">
            <path d="M4 1h8a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V3a2 2 0 0 1 2-2m0 1a1 1 0 0 0-1 1v10a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V3a1 1 0 0 0-1-1z"/>
            <path d="M6.646 5.646a.5.5 0 1 1 .708.708L5.707 8l1.647 1.646a.5.5 0 0 1-.708.708l-2-2a.5.5 0 0 1 0-.708zm2.708 0 2 2a.5.5 0 0 1 0 .708l-2 2a.5.5 0 0 1-.708-.708L10.293 8 8.646 6.354a.5.5 0 1 1 .708-.708"/>
        </svg>
        Análise de Dados
    </h1>
    <p class="lead mb-0">Apresentação passo a passo da análise exploratória</p>
    <a href="https://www.kaggle.com/code/gaganmaahi224/eda-advanced-visualization-for-beginners/notebook" target="_blank" class="link-light"> Referencia de Estudo </a>
</div>

@if (!reportExists)
{
    <div class="alert alert-warning text-center shadow-sm" role="alert">
        <h5 class="alert-heading fw-bold">Notebook ainda não gerado</h5>
    </div>
}
else
{
    <div class="d-flex justify-content-end mb-2">
        <a href="/charts/notebook_report.html" target="_blank" class="btn btn-outline-primary btn-sm">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-box-arrow-up-right me-1" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M8.636 3.5a.5.5 0 0 0-.5-.5H1.5A1.5 1.5 0 0 0 0 4.5v10A1.5 1.5 0 0 0 1.5 16h10a1.5 1.5 0 0 0 1.5-1.5V7.864a.5.5 0 0 0-1 0V14.5a.5.5 0 0 1-.5.5h-10a.5.5 0 0 1-.5-.5v-10a.5.5 0 0 1 .5-.5h6.636a.5.5 0 0 0 .5-.5"/>
                <path fill-rule="evenodd" d="M16 .5a.5.5 0 0 0-.5-.5h-5a.5.5 0 0 0 0 1h3.793L6.146 9.146a.5.5 0 1 0 .708.708L15 1.707V5.5a.5.5 0 0 0 1 0z"/>
            </svg>
            Abrir em ecrã inteiro
        </a>
    </div>
    <div class="ratio" style="--bs-aspect-ratio: 85vh; min-height: 700px;">
        <iframe src="/charts/notebook_report.html"
                style="width: 100%; height: 100%; border: 1px solid #dee2e6; border-radius: .5rem;"
                allowfullscreen>
        </iframe>
    </div>
}
